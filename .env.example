POSTGRES_DB=rag_pageindex
POSTGRES_USER=rag
POSTGRES_PASSWORD=rag_password
DATABASE_URL=postgresql+psycopg://rag:rag_password@postgres:5432/rag_pageindex
REDIS_URL=redis://redis:6379/0

SECRET_KEY=replace-with-a-long-random-secret
SESSION_COOKIE_NAME=rag_session
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me-now

OPENAI_API_KEY=
API_PROVIDER=openai
OPENAI_BASE_URL=
OPENAI_CHAT_MODEL=gpt-5.4-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_EMBEDDING_DIMENSIONS=1536
USE_FAKE_OPENAI=false

RAG_STORAGE_DIR=/data
MAX_UPLOAD_MB=50
FRONTEND_ORIGIN=http://localhost:3111
NEXT_PUBLIC_API_BASE_URL=http://localhost:8111

ENABLE_RAG_ANYTHING=true
RAG_ANYTHING_PARSER=mineru
PDF_OCR_ENABLED=true
PDF_OCR_ENGINE=auto
PDF_OCR_LANG=vie+eng
PDF_OCR_SCALE=2.0
PDF_OCR_MAX_PAGES=100
PADDLE_OCR_LANG=vi
PADDLE_OCR_DEVICE=cpu
PAGEINDEX_MIN_PAGES=30
PAGEINDEX_COMMAND=
SYNC_INGESTION_ON_QUEUE_FAILURE=false
