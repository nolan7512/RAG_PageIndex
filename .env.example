POSTGRES_DB=rag_pageindex
POSTGRES_USER=rag
POSTGRES_PASSWORD=rag_password
POSTGRES_HOST_PORT=15432
DATABASE_URL=postgresql+psycopg://rag:rag_password@postgres:5432/rag_pageindex
REDIS_URL=redis://redis:6379/0
REDIS_HOST_PORT=16379

SECRET_KEY=replace-with-a-long-random-secret
SESSION_COOKIE_NAME=rag_session
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me-now

OPENAI_API_KEY=
API_PROVIDER=openai
OPENAI_BASE_URL=
OPENAI_CHAT_MODEL=gpt-5.4-mini
OPENAI_TEMPERATURE=0.1
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_EMBEDDING_DIMENSIONS=1536
USE_FAKE_OPENAI=false
COMPOSE_PROFILES=
OLLAMA_MODEL=deepseek-r1:1.5b
OLLAMA_HOST_PORT=11435
EMBEDDING_PROVIDER=openai
LOCAL_EMBEDDING_MODEL=BAAI/bge-m3
LOCAL_EMBEDDING_DIMENSIONS=1024
LOCAL_EMBEDDING_DEVICE=cpu
LOCAL_EMBEDDING_BATCH_SIZE=8
RERANKER_PROVIDER=none
LOCAL_RERANKER_MODEL=BAAI/bge-reranker-v2-m3
LOCAL_RERANKER_DEVICE=cpu
RERANKER_TOP_K=30
RERANKER_WEIGHT=0.35

RAG_STORAGE_DIR=/data
MAX_UPLOAD_MB=50
FRONTEND_HOST_PORT=3111
API_HOST_PORT=8111
FRONTEND_ORIGIN=http://localhost:3111
CORS_ORIGINS=http://localhost:3111
NEXT_PUBLIC_API_BASE_URL=http://localhost:8111

ENABLE_RAG_ANYTHING=true
RAG_ANYTHING_PARSER=mineru
PDF_OCR_ENABLED=true
PDF_OCR_ENGINE=auto
PDF_OCR_LANG=vie+eng+chi_sim
PDF_OCR_SCALE=2.0
PDF_OCR_MAX_PAGES=100
OCR_MIN_LINE_CONFIDENCE=0.35
PADDLE_OCR_LANG=vi,ch
PADDLE_OCR_DEVICE=cpu
VIETOCR_DEVICE=cpu
VIETOCR_CONFIG=vgg_transformer
PAGEINDEX_MIN_PAGES=1
PAGEINDEX_COMMAND=
SYNC_INGESTION_ON_QUEUE_FAILURE=false

CHAT_CONTEXT_LIMIT=5
CHAT_CONTEXT_MAX_CHARS=3500
CHAT_CHUNK_MAX_CHARS=900
CHAT_MIN_RELEVANCE_SCORE=0.35
CHAT_MIN_LEXICAL_SCORE=0.08
